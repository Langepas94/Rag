TELEGRAM_BOT_TOKEN=...
BOT_PASSWORD=202020

# Normal free-text MCP/travel agent.
DEEPSEEK_API_KEY=...
# or:
# LLM_API_KEY=...
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Web admin.
ADMIN_ADDR=127.0.0.1:8080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=...

# Persistence.
DIGEST_INTERVAL_MINUTES=360
STATE_FILE=state.json
SESSIONS_DIR=sessions

# RAG bridge. The bot auto-detects these when it is started from the
# ollama-rag-indexer tree, but set them explicitly on a VPS/systemd service.
RAG_WORKDIR=/opt/ollama-rag-indexer
RAG_PYTHON=/opt/ollama-rag-indexer/.venv/bin/python
RAG_INDEX=/opt/ollama-rag-indexer/indexes-real-qwen/structural
RAG_EMBED_MODEL=qwen3-embedding
RAG_CHAT_MODEL=qwen2.5:7b
RAG_SEARCH_MODE=hybrid

# Optional retrieval tuning.
# RAG_REWRITE_QUERY=1
# RAG_TOP_K=5
# RAG_CANDIDATE_K=12
# RAG_SIMILARITY_THRESHOLD=0.8
